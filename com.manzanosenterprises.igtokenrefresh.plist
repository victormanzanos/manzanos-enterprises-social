<?xml version="1.0" encoding="UTF-8"?>
<!--
LaunchAgent: refresco semanal del token de Instagram (domingos 10:15 local).
Renueva MANZANOSENTERPRISES_IG_ACCESS_TOKEN antes de que caduque (~60 días).

Instalación:
  cp ~/manzanos-enterprises-social/com.manzanosenterprises.igtokenrefresh.plist ~/Library/LaunchAgents/
  launchctl load -w ~/Library/LaunchAgents/com.manzanosenterprises.igtokenrefresh.plist
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.manzanosenterprises.igtokenrefresh</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/victor/manzanos-enterprises-social/run_refresh.sh</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key><integer>0</integer>
        <key>Hour</key><integer>10</integer>
        <key>Minute</key><integer>15</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/victor/manzanos-enterprises-social/token-refresh-launchd.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/victor/manzanos-enterprises-social/token-refresh-launchd.err.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
